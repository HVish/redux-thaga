{
  "name": "@hvish/redux-thaga",
  "version": "1.0.0-rc.0",
  "description": "redux middleware for redux-saga with redux-thunk capabilities",
  "repository": {
    "type": "git",
    "url": "https://github.com/HVish/redux-thaga"
  },
  "bugs": {
    "url": "https://github.com/HVish/redux-thaga/issues"
  },
  "main": "dist/cjs/redux-thaga.cjs",
  "module": "dist/redux-thaga.legacy-esm.js",
  "types": "dist/cjs/redux-thaga.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/redux-thaga.d.mts",
        "default": "./dist/redux-thaga.mjs"
      },
      "require": {
        "types": "./dist/cjs/redux-thaga.d.ts",
        "default": "./dist/cjs/redux-thaga.cjs"
      },
      "default": "./dist/cjs/redux-thaga.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "jest --ci --coverage",
    "test:watch": "jest --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"{src,examples}/**/*.{js,ts}\"",
    "format:check": "prettier --check \"{src,examples}/**/*.{js,ts}\"",
    "version": "echo $npm_package_version",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "redux",
    "redux-saga",
    "redux-thunk"
  ],
  "author": "Vishnu Singh",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "redux-saga": "^1.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": ">= 2",
    "redux-saga": ">= 1"
  }
}
